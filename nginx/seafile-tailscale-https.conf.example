# Optional internal HTTPS entrypoint for Tailscale/private DNS.
# Replace certificate paths and server_name before use.

server {
    listen 80;
    listen [::]:80;
    server_name cloud.internal.example.com;

    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name cloud.internal.example.com;

    ssl_certificate     /etc/nginx/ssl/cloud.internal.example.com/fullchain.pem;
    ssl_certificate_key /etc/nginx/ssl/cloud.internal.example.com/privkey.pem;

    client_max_body_size 0;
    proxy_read_timeout 310s;
    proxy_send_timeout 310s;

    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header Connection "";
    }
}
